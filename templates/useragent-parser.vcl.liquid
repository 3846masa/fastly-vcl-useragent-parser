sub get_parsed_useragent STRING {
  declare local var.result STRING;
  set req.http.uap = "";

  {% for parser in user_agent_parsers -%}
  if (req.http.user-agent ~ "{{ parser.regex | escape_vcl_regex }}") {
    {% if parser.family_replacement -%}
      set req.http.uap:family = {"{{ parser.family_replacement | to_vcl_replacement }}"};
    {%- else -%}
      set req.http.uap:family = re.group.1;
    {%- endif %}
    {% if parser.v1_replacement -%}
      set req.http.uap:major = {"{{ parser.v1_replacement | to_vcl_replacement }}"};
    {%- else -%}
      set req.http.uap:major = re.group.2;
    {%- endif %}
    {% if parser.v2_replacement -%}
      set req.http.uap:minor = {"{{ parser.v2_replacement | to_vcl_replacement }}"};
    {%- else -%}
      set req.http.uap:minor = re.group.3;
    {%- endif %}
    {% if parser.v3_replacement -%}
      set req.http.uap:patch = {"{{ parser.v3_replacement | to_vcl_replacement }}"};
    {%- else -%}
      set req.http.uap:patch = re.group.4;
    {%- endif %}
  } else
  {% endfor -%}
  {}

  set var.result = req.http.uap;
  unset req.http.uap;

  return var.result;
}

